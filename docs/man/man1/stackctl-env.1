.nh
.TH "stackctl" "1" "" "stackctl" ""

.SH NAME
stackctl-env - Print app-ready environment variables


.SH SYNOPSIS
\fBstackctl env [service...] [flags]\fP


.SH DESCRIPTION
Print app-ready environment variables from the current stack config.

.PP
By default this prints shell-safe KEY=value assignments. Use --export
when you want export-prefixed lines for eval/source workflows, or --json
for tooling.


.SH OPTIONS
\fB--export\fP[=false]
	Prefix assignments with export for shell eval workflows

.PP
\fB-h\fP, \fB--help\fP[=false]
	help for env

.PP
\fB-j\fP, \fB--json\fP[=false]
	Print environment variables as JSON


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--accessible\fP[=false]
	Render interactive prompts and spinners in accessible mode

.PP
\fB--log-file\fP=""
	Write internal logs to this path ('-' writes to stderr)

.PP
\fB--log-format\fP=""
	Set the internal log format for --log-file (text, json, logfmt)

.PP
\fB--log-level\fP=""
	Set the internal log level when --log-file is enabled

.PP
\fB--plain\fP[=false]
	Force the legacy plain-text config wizard instead of the form UI

.PP
\fB-q\fP, \fB--quiet\fP[=false]
	Suppress non-essential progress output

.PP
\fB--stack\fP=""
	Select a named stack config (overrides STACKCTL_STACK and the saved current stack)

.PP
\fB-v\fP, \fB--verbose\fP[=false]
	Print extra lifecycle detail


.SH EXAMPLE
.EX
  stackctl env
  stackctl env --export
  stackctl env postgres redis
  stackctl env --json
.EE


.SH SEE ALSO
\fBstackctl(1)\fP
