.nh
.TH "stackctl" "1" "" "stackctl" ""

.SH NAME
stackctl-doctor - Run diagnostics and optional fixes for the local stack


.SH SYNOPSIS
\fBstackctl doctor [flags]\fP


.SH DESCRIPTION
Run diagnostics and optional fixes for the local stack


.SH OPTIONS
\fB--check-images\fP[=false]
	Resolve configured service images against their registries

.PP
\fB--fix\fP[=false]
	Try to apply supported fixes for doctor findings

.PP
\fB-h\fP, \fB--help\fP[=false]
	help for doctor

.PP
\fB-y\fP, \fB--yes\fP[=false]
	Assume yes for automatic fix prompts


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--accessible\fP[=false]
	Render interactive prompts and spinners in accessible mode

.PP
\fB--log-file\fP=""
	Write internal logs to this path ('-' writes to stderr)

.PP
\fB--log-format\fP=""
	Set the internal log format for --log-file (text, json, logfmt)

.PP
\fB--log-level\fP=""
	Set the internal log level when --log-file is enabled

.PP
\fB--plain\fP[=false]
	Force the legacy plain-text config wizard instead of the form UI

.PP
\fB-q\fP, \fB--quiet\fP[=false]
	Suppress non-essential progress output

.PP
\fB--stack\fP=""
	Select a named stack config (overrides STACKCTL_STACK and the saved current stack)

.PP
\fB-v\fP, \fB--verbose\fP[=false]
	Print extra lifecycle detail


.SH EXAMPLE
.EX
  stackctl doctor
  stackctl doctor --check-images
  stackctl doctor --fix --yes
.EE


.SH SEE ALSO
\fBstackctl(1)\fP
