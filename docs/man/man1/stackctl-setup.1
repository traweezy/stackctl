.nh
.TH "stackctl" "1" "" "stackctl" ""

.SH NAME
stackctl-setup - Prepare the local machine and stackctl config


.SH SYNOPSIS
\fBstackctl setup [flags]\fP


.SH DESCRIPTION
Prepare the local machine and stackctl config


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for setup

.PP
\fB--install\fP[=false]
	Install supported missing dependencies

.PP
\fB--interactive\fP[=false]
	Force interactive config setup

.PP
\fB--non-interactive\fP[=false]
	Skip prompts and use defaults where possible

.PP
\fB--yes\fP[=false]
	Assume yes for installation prompts


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--accessible\fP[=false]
	Render interactive prompts and spinners in accessible mode

.PP
\fB--log-file\fP=""
	Write internal logs to this path ('-' writes to stderr)

.PP
\fB--log-format\fP=""
	Set the internal log format for --log-file (text, json, logfmt)

.PP
\fB--log-level\fP=""
	Set the internal log level when --log-file is enabled

.PP
\fB--plain\fP[=false]
	Force the legacy plain-text config wizard instead of the form UI

.PP
\fB-q\fP, \fB--quiet\fP[=false]
	Suppress non-essential progress output

.PP
\fB--stack\fP=""
	Select a named stack config (overrides STACKCTL_STACK and the saved current stack)

.PP
\fB-v\fP, \fB--verbose\fP[=false]
	Print extra lifecycle detail


.SH EXAMPLE
.EX
  stackctl setup
  stackctl setup --non-interactive
  stackctl setup --install --yes
.EE


.SH SEE ALSO
\fBstackctl(1)\fP
