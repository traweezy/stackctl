.nh
.TH "stackctl" "1" "" "stackctl" ""

.SH NAME
stackctl-services - Show full connection details for configured services


.SH SYNOPSIS
\fBstackctl services [flags]\fP


.SH DESCRIPTION
Show full connection details for configured services


.SH OPTIONS
\fB--copy\fP=""
	Copy a service value such as postgres, meilisearch-api-key, seaweedfs, seaweedfs-secret-key, pgadmin, or cockpit

.PP
\fB-h\fP, \fB--help\fP[=false]
	help for services

.PP
\fB-j\fP, \fB--json\fP[=false]
	Print service details as JSON


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--accessible\fP[=false]
	Render interactive prompts and spinners in accessible mode

.PP
\fB--log-file\fP=""
	Write internal logs to this path ('-' writes to stderr)

.PP
\fB--log-format\fP=""
	Set the internal log format for --log-file (text, json, logfmt)

.PP
\fB--log-level\fP=""
	Set the internal log level when --log-file is enabled

.PP
\fB--plain\fP[=false]
	Force the legacy plain-text config wizard instead of the form UI

.PP
\fB-q\fP, \fB--quiet\fP[=false]
	Suppress non-essential progress output

.PP
\fB--stack\fP=""
	Select a named stack config (overrides STACKCTL_STACK and the saved current stack)

.PP
\fB-v\fP, \fB--verbose\fP[=false]
	Print extra lifecycle detail


.SH EXAMPLE
.EX
  stackctl services
  stackctl services --json
  stackctl services --copy meilisearch-api-key
  stackctl services --copy seaweedfs
  stackctl services --copy seaweedfs-secret-key
.EE


.SH SEE ALSO
\fBstackctl(1)\fP
