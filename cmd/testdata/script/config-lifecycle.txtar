# A default user path should create, validate, scaffold, inspect, and reset config.
exec stackctl config init --non-interactive
stdout 'wrote managed compose file '
stdout 'Saved config to '
exists .config/stackctl/config.yaml
exists .local/share/stackctl/stacks/dev-stack/compose.yaml
exists .local/share/stackctl/stacks/dev-stack/nats.conf

exec stackctl config view
stdout 'name: dev-stack'
stdout $WORK/.local/share/stackctl/stacks/dev-stack
stdout 'postgres_database: app'
stdout 'postgres_username: app'
stdout 'postgres_password: app'
stdout 'redis_password: ""'
stdout 'nats_token: stackctl'
stdout 'pgadmin_email: admin@example.com'
stdout 'pgadmin_password: admin'
stdout 'include_nats: true'

exec stackctl config validate
stdout 'config is valid'

exec stackctl config scaffold --force
stdout 'wrote managed compose file '
cmp .local/share/stackctl/stacks/dev-stack/compose.yaml expected-compose.yaml
cmp .local/share/stackctl/stacks/dev-stack/nats.conf expected-nats.conf

exec stackctl config path
stdout '/.config/stackctl/config.yaml'

exec stackctl connect
cmp stdout expected-connect.txt

exec stackctl env postgres
cmp stdout expected-env.txt

! exec stackctl logs -s invalid
stderr 'invalid service "invalid"; valid values: postgres, redis, nats, seaweedfs, meilisearch, pgadmin'

exec stackctl config reset --force
stdout 'Reset config at '
exec stackctl config validate
stdout 'config is valid'
exec stackctl config view
stdout 'name: dev-stack'
stdout $WORK/.local/share/stackctl/stacks/dev-stack
stdout 'postgres_database: app'
stdout 'nats_token: stackctl'
stdout 'pgadmin_email: admin@example.com'

-- expected-compose.yaml --
name: "dev-stack"

services:
  postgres:
    image: "docker.io/library/postgres:16"
    container_name: "local-postgres"
    restart: unless-stopped
    environment:
      POSTGRES_USER: "app"
      POSTGRES_PASSWORD: "app"
      POSTGRES_DB: "app"
    ports:
      - "5432:5432"
    volumes:
      - postgres_data:/var/lib/postgresql/data
  redis:
    image: "docker.io/library/redis:7"
    container_name: "local-redis"
    restart: unless-stopped
    command:
      - redis-server
      - --appendonly
      - "no"
      - --save
      - "3600 1 300 100 60 10000"
      - --maxmemory-policy
      - "noeviction"
    ports:
      - "6379:6379"
    volumes:
      - redis_data:/data
  nats:
    image: "docker.io/library/nats:2.12.5"
    container_name: "local-nats"
    restart: unless-stopped
    command:
      - --config
      - /etc/nats/nats.conf
    ports:
      - "4222:4222"
    volumes:
      - ./nats.conf:/etc/nats/nats.conf:ro
  pgadmin:
    image: "docker.io/dpage/pgadmin4:latest"
    container_name: "local-pgadmin"
    restart: unless-stopped
    environment:
      PGADMIN_DEFAULT_EMAIL: "admin@example.com"
      PGADMIN_DEFAULT_PASSWORD: "admin"
      PGADMIN_CONFIG_SERVER_MODE: "False"
    ports:
      - "8081:80"
    volumes:
      - pgadmin_data:/var/lib/pgadmin
    depends_on:
      - postgres

volumes:
  postgres_data:
  redis_data:
  pgadmin_data:
-- expected-nats.conf --
port: 4222

authorization {
  token: "stackctl"
}
-- expected-connect.txt --
Postgres
  postgres://app:app@localhost:5432/app

Redis
  redis://localhost:6379

NATS
  nats://stackctl@localhost:4222

pgAdmin
  http://localhost:8081

Cockpit
  https://localhost:9090
-- expected-env.txt --
# stackctl
STACKCTL_STACK='dev-stack'

# Postgres
DATABASE_URL='postgres://app:app@localhost:5432/app'
POSTGRES_URL='postgres://app:app@localhost:5432/app'
PGHOST='localhost'
PGPORT='5432'
PGDATABASE='app'
PGUSER='app'
PGPASSWORD='app'
POSTGRES_HOST='localhost'
POSTGRES_PORT='5432'
POSTGRES_DB='app'
POSTGRES_USER='app'
POSTGRES_PASSWORD='app'
