# Root and subcommand help should expose the current CLI surface.
exec stackctl --help
stdout 'stackctl setup'
stdout 'stackctl services'
stdout 'stackctl exec postgres -- psql -U app -d app'
stdout 'factory-reset'
stdout '--stack'

exec stackctl start --help
stdout 'start [service...]'
stdout 'stackctl start postgres'

exec stackctl stop --help
stdout 'stop [service...]'
stdout 'stackctl stop redis nats'

exec stackctl restart --help
stdout 'restart [service...]'
stdout 'stackctl restart postgres'

exec stackctl services --help
stdout '--json'
stdout 'stackctl services --json'

exec stackctl exec --help
stdout '--no-tty'
stdout 'stackctl exec postgres -- psql -U app -d app'

exec stackctl db shell --help
stdout '--no-tty'
stdout 'stackctl db shell -- -c'

exec stackctl ports --help
stdout 'Show host-to-service port mappings'

exec stackctl status --help
stdout '--json'
stdout '--verbose'

exec stackctl config init --help
stdout '--force'
stdout '--non-interactive'

exec stackctl logs --help
stdout '--service'
stdout '--tail'
stdout '--watch'

exec stackctl health --help
stdout '--watch'
stdout '--interval'

exec stackctl reset --help
stdout '--force'
stdout '--volumes'

exec stackctl factory-reset --help
stdout 'DANGEROUS'
stdout '--force'

exec stackctl setup --help
stdout '--install'
stdout '--interactive'
stdout '--non-interactive'
stdout '--yes'

exec stackctl version
stdout 'version: [0-9]+\.[0-9]+\.[0-9]+'
